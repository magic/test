{
  "name": "@magic/test",
  "version": "0.2.30",
  "author": "Wizards & Witches",
  "description": "simple yet powerful unit testing library",
  "license": "AGPL-3.0",
  "homepage": "https://magic.github.io/test",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "bin": {
    "t": "src/bin/t.ts",
    "magic-test": "src/bin/t.ts",
    "magic-test-native": "src/bin/node-test-runner.ts"
  },
  "scripts": {
    "start": "node src/bin/t.ts -p",
    "build:docs": "NODE_ENV=production magic build",
    "prod": "NODE_ENV=production magic build serve",
    "clean": "magic clean",
    "serve": "magic serve",
    "dev": "magic dev",
    "test": "node src/bin/t.ts",
    "test:native": "node --test src/bin/node-test-runner.ts --coverage && c8 report",
    "test:ci": "node src/bin/t.ts -p",
    "coverage": "node src/bin/t.ts",
    "format": "f -w --exclude docs",
    "format:check": "f --exclude docs",
    "tsc": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "engineStrict": true,
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magic/test.git"
  },
  "bugs": {
    "url": "https://github.com/magic/test/issues"
  },
  "dependencies": {
    "@magic/cli": "0.0.53",
    "@magic/deep": "0.1.20",
    "@magic/error": "0.0.21",
    "@magic/fs": "0.0.37",
    "@magic/log": "0.1.21",
    "@magic/types": "0.1.33",
    "c8": "11.0.0",
    "canvas": "3.2.3",
    "happy-dom": "20.8.9"
  },
  "devDependencies": {
    "@magic-modules/git-badges": "0.0.12",
    "@magic-modules/light-switch": "0.0.12",
    "@magic-modules/no-spy": "0.0.9",
    "@magic-modules/pre": "0.0.12",
    "@magic-themes/docs": "0.0.15",
    "@magic/core": "0.0.156",
    "@magic/format": "0.0.73",
    "@types/node": "25.5.2",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.1",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  },
  "contributors": [
    {
      "name": "jascha ehrenreich",
      "github": "jaeh"
    }
  ]
}
